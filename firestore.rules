rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: authenticated users can only read their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Sessions: authenticated users can read their own sessions,
    // guest sessions (userId starts with "guest_") are readable without auth
    match /sessions/{sessionId} {
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid)
                   || resource.data.userId[0:6] == "guest_";
      allow write: if false;
    }

    // Questions: anyone can read (guests need access for practice)
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    // Responses: no client access needed (backend only)
    match /responses/{responseId} {
      allow read, write: if false;
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
