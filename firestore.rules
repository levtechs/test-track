rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: authenticated users can only read their own document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Sessions: authenticated users can only read their own sessions
    match /sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Questions: anyone can read (guests need access for practice)
    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    // Responses: no client access needed (backend only)
    match /responses/{responseId} {
      allow read, write: if false;
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
